      "path": "registry/intent/confirm-destructive-action/simple-dialog.tsx",
      "content": "'use client'\n\nimport { TriangleAlertIcon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport {\n  Dialog,\n  DialogClose,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from '@/components/ui/dialog'\n\nexport function SimpleDialogDecision() {\n  return (\n    <div className=\"bg-card w-full max-w-xs rounded-xl border p-5 shadow-sm\">\n      <div className=\"flex flex-col gap-1\">\n        <span className=\"text-sm font-semibold\">Project Atlas</span>\n        <span className=\"text-muted-foreground text-xs\">\n          12 members · Created Jan 2024\n        </span>\n      </div>\n      <div className=\"mt-4\">\n        <Dialog>\n          <DialogTrigger asChild>\n            <Button variant=\"destructive\" size=\"sm\" className=\"w-full\">\n              Delete project\n            </Button>\n          </DialogTrigger>\n          <DialogContent>\n            <DialogHeader>\n              <div className=\"bg-destructive/10 mb-1 flex size-10 items-center justify-center rounded-full\">\n                <TriangleAlertIcon className=\"text-destructive size-5\" />\n              </div>\n              <DialogTitle>Delete project?</DialogTitle>\n              <DialogDescription>\n                Project Atlas and all its data will be permanently deleted. This\n                action cannot be undone.\n              </DialogDescription>\n            </DialogHeader>\n            <DialogFooter>\n              <DialogClose asChild>\n                <Button variant=\"outline\">Cancel</Button>\n              </DialogClose>\n              <Button variant=\"destructive\">Delete project</Button>\n            </DialogFooter>\n          </DialogContent>\n        </Dialog>\n      </div>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/intent/confirm-destructive-action/simple-dialog.tsx"
    }
  ],
  "type": "registry:block"
}