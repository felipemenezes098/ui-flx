    {
      "path": "registry/patterns/dropdown/dropdown-09.tsx",
      "content": "import { Avatar, AvatarFallback, AvatarImage } from '@/components/ui/avatar'\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuGroup,\n  DropdownMenuItem,\n  DropdownMenuLabel,\n  DropdownMenuSeparator,\n  DropdownMenuShortcut,\n  DropdownMenuTrigger,\n} from '@/components/ui/dropdown-menu'\nimport {\n  CreditCardIcon,\n  LogOutIcon,\n  SettingsIcon,\n  UserIcon,\n} from 'lucide-react'\n\nexport function Dropdown09() {\n  return (\n    <DropdownMenu>\n      <DropdownMenuTrigger className=\"focus-visible:ring-ring rounded-full outline-hidden focus-visible:ring-2\">\n        <Avatar>\n          <AvatarImage src=\"https://github.com/shadcn.png\" alt=\"Shadcn Logo\" />\n          <AvatarFallback>SH</AvatarFallback>\n        </Avatar>\n      </DropdownMenuTrigger>\n      <DropdownMenuContent align=\"end\" className=\"w-56\">\n        <DropdownMenuLabel className=\"text-foreground flex flex-col gap-0.5\">\n          <span className=\"text-sm font-medium\">Shadcn</span>\n          <span className=\"text-muted-foreground text-xs font-normal\">\n            shadcn@example.com\n          </span>\n        </DropdownMenuLabel>\n        <DropdownMenuSeparator />\n        <DropdownMenuGroup>\n          <DropdownMenuItem>\n            <UserIcon />\n            Profile\n            <DropdownMenuShortcut>⇧⌘P</DropdownMenuShortcut>\n          </DropdownMenuItem>\n          <DropdownMenuItem>\n            <CreditCardIcon />\n            Billing\n          </DropdownMenuItem>\n          <DropdownMenuItem>\n            <SettingsIcon />\n            Settings\n          </DropdownMenuItem>\n        </DropdownMenuGroup>\n        <DropdownMenuSeparator />\n        <DropdownMenuItem variant=\"destructive\">\n          <LogOutIcon />\n          Log out\n        </DropdownMenuItem>\n      </DropdownMenuContent>\n    </DropdownMenu>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/patterns/dropdown/dropdown-09.tsx"
    }
  ],
  "type": "registry:block"
}