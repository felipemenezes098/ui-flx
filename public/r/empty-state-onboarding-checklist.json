{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "empty-state-onboarding-checklist",
  "title": "Onboarding Checklist",
  "description": "Onboarding Checklist — Empty State.",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "button"
  ],
  "files": [
    {
      "path": "registry/intent/empty-state/onboarding-checklist.tsx",
      "content": "'use client'\n\nimport { useState } from 'react'\nimport { CheckIcon, RocketIcon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport { cn } from '@/lib/utils'\n\nconst STEPS = [\n  { id: 'profile', label: 'Complete your profile', done: true },\n  { id: 'invite', label: 'Invite a teammate', done: true },\n  { id: 'project', label: 'Create your first project', done: false },\n  { id: 'integrate', label: 'Connect an integration', done: false },\n]\n\nexport function OnboardingChecklistDecision() {\n  const [steps, setSteps] = useState(STEPS)\n  const done = steps.filter((s) => s.done).length\n  const pct = Math.round((done / steps.length) * 100)\n\n  return (\n    <div className=\"bg-card w-full max-w-sm rounded-xl border p-5 shadow-sm\">\n      <div className=\"flex items-center gap-3\">\n        <div className=\"bg-primary/10 flex size-10 items-center justify-center rounded-full\">\n          <RocketIcon className=\"text-primary size-5\" />\n        </div>\n        <div className=\"flex flex-col\">\n          <span className=\"text-sm font-semibold\">Get set up</span>\n          <span className=\"text-muted-foreground text-xs\">\n            {done} of {steps.length} steps complete\n          </span>\n        </div>\n      </div>\n\n      <div className=\"bg-muted mt-4 h-1.5 w-full overflow-hidden rounded-full\">\n        <div\n          className=\"bg-primary h-full rounded-full transition-all\"\n          style={{ width: `${pct}%` }}\n        />\n      </div>\n\n      <ul className=\"mt-4 flex flex-col gap-1\">\n        {steps.map((step) => (\n          <li key={step.id}>\n            <button\n              type=\"button\"\n              onClick={() =>\n                setSteps((prev) =>\n                  prev.map((s) =>\n                    s.id === step.id ? { ...s, done: !s.done } : s,\n                  ),\n                )\n              }\n              className=\"hover:bg-muted/60 flex w-full items-center gap-3 rounded-lg p-2 text-left transition-colors\"\n            >\n              <span\n                className={cn(\n                  'flex size-5 shrink-0 items-center justify-center rounded-full border',\n                  step.done\n                    ? 'bg-primary border-primary text-primary-foreground'\n                    : 'border-muted-foreground/40',\n                )}\n              >\n                {step.done && <CheckIcon className=\"size-3\" />}\n              </span>\n              <span\n                className={cn(\n                  'text-sm',\n                  step.done && 'text-muted-foreground line-through',\n                )}\n              >\n                {step.label}\n              </span>\n            </button>\n          </li>\n        ))}\n      </ul>\n\n      <Button className=\"mt-4 w-full\" disabled={done < steps.length}>\n        {done < steps.length ? 'Finish remaining steps' : 'You’re all set 🎉'}\n      </Button>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/intent/empty-state/onboarding-checklist.tsx"
    }
  ],
  "type": "registry:block"
}