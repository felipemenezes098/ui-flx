{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "reset-password-otp-code",
  "title": "OTP Code",
  "description": "OTP Code for Reset Password.",
  "dependencies": [
    "lucide-react",
    "input-otp"
  ],
  "registryDependencies": [
    "button",
    "input-otp"
  ],
  "files": [
    {
      "path": "registry/intent/reset-password/otp-code.tsx",
      "content": "'use client'\n\nimport { useState } from 'react'\nimport { ShieldCheckIcon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport {\n  InputOTP,\n  InputOTPGroup,\n  InputOTPSlot,\n} from '@/components/ui/input-otp'\n\nexport function OtpCodeDecision() {\n  const [code, setCode] = useState('')\n\n  return (\n    <div className=\"bg-card w-full max-w-xs rounded-xl border p-6 shadow-sm\">\n      <div className=\"bg-primary/10 mb-1 flex size-10 items-center justify-center rounded-full\">\n        <ShieldCheckIcon className=\"text-primary size-5\" />\n      </div>\n      <div className=\"mt-3 flex flex-col gap-1\">\n        <span className=\"text-base font-semibold\">Enter your code</span>\n        <span className=\"text-muted-foreground text-xs\">\n          We sent a 6-digit code to{' '}\n          <span className=\"text-foreground font-medium\">j•••@acme.com</span>.\n          Enter it below to continue.\n        </span>\n      </div>\n\n      <div className=\"mt-5 flex justify-center\">\n        <InputOTP maxLength={6} value={code} onChange={setCode}>\n          <InputOTPGroup>\n            <InputOTPSlot index={0} />\n            <InputOTPSlot index={1} />\n            <InputOTPSlot index={2} />\n            <InputOTPSlot index={3} />\n            <InputOTPSlot index={4} />\n            <InputOTPSlot index={5} />\n          </InputOTPGroup>\n        </InputOTP>\n      </div>\n\n      <Button className=\"mt-5 w-full\" disabled={code.length < 6}>\n        Verify code\n      </Button>\n\n      <p className=\"text-muted-foreground mt-4 text-center text-[11px]\">\n        Didn&apos;t get it?{' '}\n        <a href=\"#\" className=\"text-foreground font-medium hover:underline\">\n          Resend code\n        </a>{' '}\n        · expires in 5:00\n      </p>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/intent/reset-password/otp-code.tsx"
    }
  ],
  "type": "registry:block"
}