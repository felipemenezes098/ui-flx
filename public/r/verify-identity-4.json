{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "verify-identity-4",
  "title": "Biometric",
  "description": "Biometric for Verify Identity.",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "button",
