.92-.3 3.02 1.13a10.4 10.4 0 0 1 5.5 0c2.1-1.43 3.02-1.13 3.02-1.13.6 1.52.22 2.64.11 2.92.7.77 1.13 1.75 1.13 2.95 0 4.23-2.58 5.16-5.03 5.43.4.34.75 1.02.75 2.06v3.05c0 .3.2.64.76.53A11 11 0 0 0 12 1Z\" />\n    </svg>\n  )\n}\n\nexport function SocialFirstDecision() {\n  return (\n    <div className=\"bg-card w-full max-w-xs rounded-xl border p-6 shadow-sm\">\n      <div className=\"flex flex-col gap-1\">\n        <span className=\"text-base font-semibold\">Sign in to Acme</span>\n        <span className=\"text-muted-foreground text-xs\">\n          Use a provider or your email to continue.\n        </span>\n      </div>\n\n      <div className=\"mt-5 flex flex-col gap-2\">\n        <Button variant=\"outline\" className=\"w-full justify-center gap-2\">\n          <GoogleIcon />\n          Continue with Google\n        </Button>\n        <Button variant=\"outline\" className=\"w-full justify-center gap-2\">\n          <AppleIcon />\n          Continue with Apple\n        </Button>\n        <Button variant=\"outline\" className=\"w-full justify-center gap-2\">\n          <GithubIcon />\n          Continue with GitHub\n        </Button>\n      </div>\n\n      <div className=\"my-5 flex items-center gap-3\">\n        <span className=\"bg-border h-px flex-1\" />\n        <span className=\"text-muted-foreground text-[11px] uppercase\">\n          or\n        </span>\n        <span className=\"bg-border h-px flex-1\" />\n      </div>\n\n      <div className=\"flex flex-col gap-1.5\">\n        <Label htmlFor=\"social-email\" className=\"text-xs\">\n          Email\n        </Label>\n        <Input\n          id=\"social-email\"\n          type=\"email\"\n          placeholder=\"you@acme.com\"\n          autoComplete=\"email\"\n        />\n      </div>\n      <Button className=\"mt-3 w-full\">Continue</Button>\n    </div>\n  )\n}\n",
