{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog-16",
  "title": "Invite team",
  "description": "Icon header plus email field.",
  "dependencies": [],
  "registryDependencies": [
    "dialog",
    "button",
    "input",
    "field"
  ],
  "files": [
    {
      "path": "registry/patterns/dialog/dialog-16.tsx",
      "content": "import { UsersIcon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport {\n  Dialog,\n  DialogClose,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from '@/components/ui/dialog'\nimport { Field, FieldDescription, FieldLabel } from '@/components/ui/field'\nimport { Input } from '@/components/ui/input'\n\nexport function Dialog16() {\n  return (\n    <Dialog>\n      <DialogTrigger asChild>\n        <Button variant=\"outline\">Invite team</Button>\n      </DialogTrigger>\n      <DialogContent className=\"sm:max-w-md\">\n        <DialogHeader>\n          <div className=\"flex flex-col gap-3\">\n            <div className=\"bg-primary/10 text-primary flex size-10 items-center justify-center rounded-full\">\n              <UsersIcon className=\"size-5\" />\n            </div>\n            <div className=\"flex flex-col gap-2\">\n              <DialogTitle>Invite your team</DialogTitle>\n              <DialogDescription>\n                Add colleagues by email. They will join as editors on this\n                workspace.\n              </DialogDescription>\n            </div>\n          </div>\n        </DialogHeader>\n        <Field>\n          <FieldLabel htmlFor=\"dialog-16-email\">Email address</FieldLabel>\n          <Input\n            id=\"dialog-16-email\"\n            type=\"email\"\n            placeholder=\"colleague@company.com\"\n          />\n          <FieldDescription>\n            Separate multiple addresses with commas.\n          </FieldDescription>\n        </Field>\n        <DialogFooter>\n          <DialogClose asChild>\n            <Button variant=\"outline\">Cancel</Button>\n          </DialogClose>\n          <Button>Send invites</Button>\n        </DialogFooter>\n      </DialogContent>\n    </Dialog>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/patterns/dialog/dialog-16.tsx"
    }
  ],
  "type": "registry:block"
}