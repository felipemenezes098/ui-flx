{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "confirm-destructive-action-popover-confirm",
  "title": "Popover Confirm",
  "description": "Popover Confirm — Confirm Destructive Action.",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "popover",
    "button"
  ],
  "files": [
    {
      "path": "registry/intent/confirm-destructive-action/popover-confirm.tsx",
      "content": "'use client'\n\nimport { FileTextIcon, Trash2Icon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport {\n  Popover,\n  PopoverContent,\n  PopoverTrigger,\n} from '@/components/ui/popover'\n\nconst files = [\n  { name: 'Q4 Report.pdf', size: '2.4 MB' },\n  { name: 'Budget 2025.xlsx', size: '840 KB' },\n  { name: 'Design Assets.zip', size: '18.1 MB' },\n]\n\nexport function PopoverConfirmDecision() {\n  return (\n    <div className=\"bg-card w-full max-w-xs rounded-xl border shadow-sm\">\n      <div className=\"border-b px-4 py-3\">\n        <span className=\"text-sm font-semibold\">Attachments</span>\n      </div>\n      <div className=\"flex flex-col divide-y\">\n        {files.map((file) => (\n          <div key={file.name} className=\"flex items-center gap-3 px-4 py-2.5\">\n            <FileTextIcon className=\"text-muted-foreground size-4 shrink-0\" />\n            <div className=\"min-w-0 flex-1\">\n              <p className=\"truncate text-sm\">{file.name}</p>\n              <p className=\"text-muted-foreground text-xs\">{file.size}</p>\n            </div>\n            <Popover>\n              <PopoverTrigger asChild>\n                <Button\n                  variant=\"ghost\"\n                  size=\"icon-sm\"\n                  className=\"text-muted-foreground hover:text-destructive shrink-0\"\n                >\n                  <Trash2Icon className=\"size-4\" />\n                </Button>\n              </PopoverTrigger>\n              <PopoverContent className=\"w-56\" side=\"left\">\n                <div className=\"flex flex-col gap-3\">\n                  <div>\n                    <p className=\"text-sm font-medium\">Remove file?</p>\n                    <p className=\"text-muted-foreground mt-0.5 text-xs\">\n                      {file.name} will be detached from this record.\n                    </p>\n                  </div>\n                  <div className=\"flex justify-end gap-2\">\n                    <Button variant=\"outline\" size=\"sm\">\n                      Cancel\n                    </Button>\n                    <Button variant=\"destructive\" size=\"sm\">\n                      Remove\n                    </Button>\n                  </div>\n                </div>\n              </PopoverContent>\n            </Popover>\n          </div>\n        ))}\n      </div>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/intent/confirm-destructive-action/popover-confirm.tsx"
    }
  ],
  "type": "registry:block"
}