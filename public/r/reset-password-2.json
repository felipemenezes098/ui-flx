{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "reset-password-2",
  "title": "OTP Code",
  "description": "OTP Code for Reset Password.",
  "dependencies": [
    "lucide-react",
    "input-otp"
  ],
  "registryDependencies": [
    "button",
    "card",
    "input-otp"
  ],
  "files": [
    {
      "path": "registry/intents/auth/reset-password/reset-password-2.tsx",
      "content": "'use client'\n\nimport { useState } from 'react'\nimport { ShieldCheckIcon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport {\n  Card,\n  CardContent,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from '@/components/ui/card'\nimport {\n  InputOTP,\n  InputOTPGroup,\n  InputOTPSlot,\n} from '@/components/ui/input-otp'\n\nexport function ResetPassword2() {\n  const [code, setCode] = useState('')\n\n  return (\n    <Card size=\"sm\">\n      <CardHeader>\n        <div className=\"bg-primary/10 mb-1 flex size-10 items-center justify-center rounded-full\">\n          <ShieldCheckIcon className=\"text-primary size-5\" />\n        </div>\n        <CardTitle>Enter your code</CardTitle>\n        <p className=\"text-muted-foreground text-xs\">\n          We sent a 6-digit code to{' '}\n          <span className=\"text-foreground font-medium\">j•••@acme.com</span>.\n          Enter it below to continue.\n        </p>\n      </CardHeader>\n\n      <CardContent className=\"flex justify-center\">\n        <InputOTP maxLength={6} value={code} onChange={setCode}>\n          <InputOTPGroup>\n            <InputOTPSlot index={0} />\n            <InputOTPSlot index={1} />\n            <InputOTPSlot index={2} />\n            <InputOTPSlot index={3} />\n            <InputOTPSlot index={4} />\n            <InputOTPSlot index={5} />\n          </InputOTPGroup>\n        </InputOTP>\n      </CardContent>\n\n      <CardFooter className=\"flex-col items-stretch gap-4\">\n        <Button className=\"w-full\" disabled={code.length < 6}>\n          Verify code\n        </Button>\n        <p className=\"text-muted-foreground text-center text-[11px]\">\n          Didn&apos;t get it?{' '}\n          <a href=\"#\" className=\"text-foreground font-medium hover:underline\">\n            Resend code\n          </a>{' '}\n          · expires in 5:00\n        </p>\n      </CardFooter>\n    </Card>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/intent/reset-password/reset-password-2.tsx"
    }
  ],
  "type": "registry:block"
}