{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tooltip-08",
  "title": "Colored",
  "description": "Primary and destructive backgrounds with matching arrow override.",
  "dependencies": [],
  "registryDependencies": [
    "tooltip",
    "button"
  ],
  "files": [
    {
      "path": "registry/patterns/tooltip/tooltip-08.tsx",
      "content": "import { Button } from '@/components/ui/button'\nimport {\n  Tooltip,\n  TooltipContent,\n  TooltipTrigger,\n} from '@/components/ui/tooltip'\n\n// Override arrow color with [&>span>svg] — radix wraps the arrow svg in a\n// positioning <span>, so a direct `>svg` selector misses it.\nexport function Tooltip08() {\n  return (\n    <div className=\"flex items-center gap-2\">\n      <Tooltip>\n        <TooltipTrigger asChild>\n          <Button>Primary</Button>\n        </TooltipTrigger>\n        <TooltipContent className=\"bg-primary text-primary-foreground [&>span>svg]:bg-primary [&>span>svg]:fill-primary\">\n          Primary tone\n        </TooltipContent>\n      </Tooltip>\n      <Tooltip>\n        <TooltipTrigger asChild>\n          <Button variant=\"outline\">Secondary</Button>\n        </TooltipTrigger>\n        <TooltipContent className=\"bg-secondary text-secondary-foreground [&>span>svg]:bg-secondary [&>span>svg]:fill-secondary\">\n          Secondary tone\n        </TooltipContent>\n      </Tooltip>\n      <Tooltip>\n        <TooltipTrigger asChild>\n          <Button variant=\"destructive\">Delete</Button>\n        </TooltipTrigger>\n        <TooltipContent className=\"bg-destructive text-white [&>span>svg]:bg-destructive [&>span>svg]:fill-destructive\">\n          This cannot be undone\n        </TooltipContent>\n      </Tooltip>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/patterns/tooltip/tooltip-08.tsx"
    }
  ],
  "type": "registry:block"
}