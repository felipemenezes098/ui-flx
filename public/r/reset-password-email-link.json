{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "reset-password-email-link",
  "title": "Email Link",
  "description": "Email Link — Reset Password.",
  "dependencies": [
    "lucide-react"
  ],
  "registryDependencies": [
    "button",
    "input",
    "label"
  ],
  "files": [
    {
      "path": "registry/intent/reset-password/email-link.tsx",
      "content": "import { KeyRoundIcon } from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\n\nexport function EmailLinkDecision() {\n  return (\n    <div className=\"bg-card w-full max-w-xs rounded-xl border p-6 shadow-sm\">\n      <div className=\"bg-primary/10 mb-1 flex size-10 items-center justify-center rounded-full\">\n        <KeyRoundIcon className=\"text-primary size-5\" />\n      </div>\n      <div className=\"mt-3 flex flex-col gap-1\">\n        <span className=\"text-base font-semibold\">Reset your password</span>\n        <span className=\"text-muted-foreground text-xs\">\n          Enter your account email and we&apos;ll send you a link to choose a\n          new password.\n        </span>\n      </div>\n\n      <div className=\"mt-5 flex flex-col gap-1.5\">\n        <Label htmlFor=\"rp-email\" className=\"text-xs\">\n          Email\n        </Label>\n        <Input\n          id=\"rp-email\"\n          type=\"email\"\n          placeholder=\"you@acme.com\"\n          autoComplete=\"email\"\n        />\n      </div>\n\n      <Button className=\"mt-4 w-full\">Send reset link</Button>\n\n      <p className=\"text-muted-foreground mt-5 text-center text-xs\">\n        Remembered it?{' '}\n        <a href=\"#\" className=\"text-foreground font-medium hover:underline\">\n          Back to sign in\n        </a>\n      </p>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/intent/reset-password/email-link.tsx"
    }
  ],
  "type": "registry:block"
}