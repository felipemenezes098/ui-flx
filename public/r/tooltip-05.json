{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tooltip-05",
  "title": "Custom delay",
  "description": "Tooltips that open instantly, after 500ms, or after 1.2s, showing different hover delay behaviors.",
  "dependencies": [],
  "registryDependencies": [
    "tooltip",
    "button"
  ],
  "files": [
    {
      "path": "registry/patterns/tooltip/tooltip-05.tsx",
      "content": "import { Button } from '@/components/ui/button'\nimport {\n  Tooltip,\n  TooltipContent,\n  TooltipProvider,\n  TooltipTrigger,\n} from '@/components/ui/tooltip'\n\nexport function Tooltip05() {\n  return (\n    <div className=\"flex items-center gap-3\">\n      <TooltipProvider delay={0}>\n        <Tooltip>\n          <TooltipTrigger render={<Button variant=\"outline\">Instant</Button>} />\n          <TooltipContent>Opens with no delay</TooltipContent>\n        </Tooltip>\n      </TooltipProvider>\n      <TooltipProvider delay={500}>\n        <Tooltip>\n          <TooltipTrigger render={<Button variant=\"outline\">500ms</Button>} />\n          <TooltipContent>Opens after 500ms hover</TooltipContent>\n        </Tooltip>\n      </TooltipProvider>\n      <TooltipProvider delay={1200}>\n        <Tooltip>\n          <TooltipTrigger render={<Button variant=\"outline\">1.2s</Button>} />\n          <TooltipContent>Opens after 1.2s hover</TooltipContent>\n        </Tooltip>\n      </TooltipProvider>\n    </div>\n  )\n}\n",
      "type": "registry:component",
      "target": "components/flx/patterns/tooltip/tooltip-05.tsx"
    }
  ],
  "type": "registry:block"
}