{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "flx-blocks-hero",
  "homepage": "https://ui.flexnative.com",
  "items": [
    {
      "name": "hero-01",
      "type": "registry:block",
      "registryDependencies": [
        "button"
      ],
      "dependencies": [
        "react-wrap-balancer",
        "motion",
        "lucide-react"
      ],
      "files": [
        {
          "path": "hero-01/hero-01.tsx",
          "type": "registry:component",
          "target": "components/flx/blocks/hero/hero-01/hero-01.tsx"
        },
        {
          "path": "hero-01/hero-01-example.tsx",
          "type": "registry:component",
          "target": "components/flx/blocks/hero/hero-01/hero-01-example.tsx"
        },
        {
          "path": "hero-01/integration-cloud.tsx",
          "type": "registry:component",
          "target": "components/flx/blocks/hero/hero-01/integration-cloud.tsx"
        }
      ],
      "title": "Hero 01",
      "description": "A centered serif hero with a soft gradient wash, pill CTA, and a floating integration cloud.",
      "meta": {
        "iframeHeight": 720
      }
    },
    {
      "name": "hero-06",
      "type": "registry:block",
      "title": "Hero 06",
      "description": "A split product hero with dual CTA, a compact logo row, and the Spot 01 illustration.",
      "registryDependencies": [
        "@flx/cta",
        "@flx/spot-01"
      ],
      "dependencies": [
        "react-wrap-balancer",
        "motion"
      ],
      "files": [
        {
          "path": "hero-06/hero-06.tsx",
          "type": "registry:component",
          "target": "components/flx/blocks/hero/hero-06/hero-06.tsx"
        },
        {
          "path": "hero-06/hero-06-example.tsx",
          "type": "registry:component",
          "target": "components/flx/blocks/hero/hero-06/hero-06-example.tsx"
        }
      ],
      "meta": {
        "iframeHeight": 820
      }
    }
  ]
}
